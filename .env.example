APP_NAME=Prelytical Secure SQL Gateway
APP_HOST=127.0.0.1
APP_PORT=8080
APP_ENV=local

SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_INSTANCE=
SQLSERVER_DATABASE=PrelyticalDemoDW
SQLSERVER_USERNAME=prelytical_readonly
SQLSERVER_PASSWORD=CHANGE_ME
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
# ODBC Driver 17 for SQL Server is supported — use the exact name from Get-OdbcDriver.
# Driver 17 (local/trusted SQL): SQLSERVER_ENCRYPT=no often works best.
# Driver 18: SQLSERVER_ENCRYPT=yes with SQLSERVER_TRUST_SERVER_CERTIFICATE=true.
SQLSERVER_TRUST_SERVER_CERTIFICATE=true
SQLSERVER_ENCRYPT=yes
SQLSERVER_CONNECTION_TIMEOUT_SECONDS=30
SQLSERVER_ALLOWED_SCHEMAS=ai,dbo
SQLSERVER_BLOCKED_SCHEMAS=sys,INFORMATION_SCHEMA
SQLSERVER_MAX_ROWS=200
SQLSERVER_QUERY_TIMEOUT_SECONDS=120

MODEL_PROVIDER=ollama
MODEL_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen2.5-coder:7b
MODEL_API_KEY=ollama
# CPU-only / low-resource servers: defaults are generous (30–60 min). Lower if you have GPU.
MODEL_TIMEOUT_SECONDS=1800
MODEL_SKIP_SUMMARIZATION=true
MODEL_MAX_SCHEMA_OBJECTS=40
BRIEF_TIMEOUT_SECONDS=3600
DEEP_DIVE_TIMEOUT_SECONDS=1800
DEEP_DIVE_MAX_QUERIES=5
# Brief prompt schema limits (tables/columns sent to the model for executive briefs)
BRIEF_MAX_TABLES_WITH_COLUMNS=18
BRIEF_MAX_COLUMNS_PER_TABLE=8
BRIEF_MAX_TABLE_INVENTORY=60
BRIEF_MAX_ENTITIES=40
# Optional: auto-save each generated brief HTML here (local folder or UNC share)
# BRIEF_EXPORT_PATH=C:\PrelyticalExports\briefs
# BRIEF_EXPORT_PATH=\\fileserver\reports\prelytical
BRIEF_EXPORT_PATH=

GATEWAY_DB_PATH=./prelytical_gateway.sqlite3
CHAT_MAX_MESSAGES=40

AUDIT_DB_PATH=./prelytical_audit.sqlite3
LOG_LEVEL=INFO

GUARDRAILS_REQUIRE_SELECT_ONLY=true
GUARDRAILS_BLOCK_PII_COLUMNS=false
GUARDRAILS_BLOCKED_COLUMN_PATTERNS=ssn,social_security,dob,date_of_birth,email,phone,account_number,routing_number,credit_card,card_number,password,secret,token,salary
GUARDRAILS_REQUIRE_ALLOWED_SCHEMA=true
GUARDRAILS_APPEND_TOP_LIMIT=true
