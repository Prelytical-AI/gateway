APP_NAME=Prelytical Secure SQL Gateway
APP_HOST=127.0.0.1
APP_PORT=8080
APP_ENV=local

SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_INSTANCE=
SQLSERVER_DATABASE=PrelyticalDemoDW
SQLSERVER_USERNAME=prelytical_readonly
SQLSERVER_PASSWORD=CHANGE_ME
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_TRUST_SERVER_CERTIFICATE=true
SQLSERVER_ENCRYPT=yes
SQLSERVER_ALLOWED_SCHEMAS=ai,dbo
SQLSERVER_BLOCKED_SCHEMAS=sys,INFORMATION_SCHEMA
SQLSERVER_MAX_ROWS=200
SQLSERVER_QUERY_TIMEOUT_SECONDS=30

MODEL_PROVIDER=ollama
MODEL_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen2.5-coder:7b
MODEL_API_KEY=ollama
MODEL_TIMEOUT_SECONDS=600
MODEL_SKIP_SUMMARIZATION=true
MODEL_MAX_SCHEMA_OBJECTS=40

AUDIT_DB_PATH=./prelytical_audit.sqlite3
LOG_LEVEL=INFO

GUARDRAILS_REQUIRE_SELECT_ONLY=true
GUARDRAILS_BLOCK_PII_COLUMNS=false
GUARDRAILS_BLOCKED_COLUMN_PATTERNS=ssn,social_security,dob,date_of_birth,email,phone,account_number,routing_number,credit_card,card_number,password,secret,token,salary
GUARDRAILS_REQUIRE_ALLOWED_SCHEMA=true
GUARDRAILS_APPEND_TOP_LIMIT=true
